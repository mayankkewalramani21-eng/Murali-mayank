	<sub-flow name="compositerequest-sf-records-sub-flow" doc:id="9d86632e-32f2-475d-b7c2-2bc1faf96a03" >
		<logger level="INFO" doc:name="start of sfcomposite records subflow" doc:id="c352ddf9-e6aa-44de-9903-447396375baf" message="start of sfcomposite records subflow" />
		<ee:transform doc:name="Payload to JAVA" doc:id="9234fd35-7930-4bc0-8f7d-4309d671b2e6" >
			<ee:message >
				<ee:set-payload ><![CDATA[%dw 2.0
output application/json
fun getType(fieldValue, fieldType, fieldFormat) = if(fieldType == "Date")
    fieldValue as Date{format: fieldFormat} default null
    else if(fieldType == "DateTime")
    fieldValue as DateTime{format: fieldFormat} default null
    else if(fieldType == "LocalDateTime")
    fieldValue as LocalDateTime{format: fieldFormat} default null
    else if(fieldType == "Time")
    fieldValue as Time{format: fieldFormat} default null
    else if(fieldType == "LocalTime")
    fieldValue as LocalTime{format: fieldFormat} default null
    else
    fieldValue
fun checkForDateObjects(data) = data match {
    case is Array -> data map checkForDateObjects($)
    case is Object -> 
        if ((namesOf(data) contains "fieldValue") and (namesOf(data) contains "fieldType")) 
            getType(data.fieldValue, data.fieldType, data.fieldFormat)
        else 
            data mapObject (($$): checkForDateObjects($))
    else -> data
}
---
checkForDateObjects(payload)
]]></ee:set-payload>
			</ee:message>
